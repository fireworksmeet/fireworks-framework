<?xml version="1.0" encoding="UTF-8" ?>
<included>
    <include resource="logback_pattern.xml"/>

    <springProperty scope="context" name="LOG_DIR" source="logging.file.path" defaultValue="/logs"/>
    <springProperty scope="context" name="LOG_NAME" source="spring.application.name" defaultValue="app"/>

    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="file" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_NAME}.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${FILE_LOG_PATTERN}</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${LOG_NAME}-%d{yyyy-MM-dd-HH}-%i.gz</fileNamePattern>
            <maxFileSize>200MB</maxFileSize>
            <MaxHistory>90</MaxHistory>
        </rollingPolicy>
    </appender>
</included>